# Copy to .env and fill in. .env is git-ignored — never commit real keys.

# 21.dev API key (for generating/fetching 21.dev components).
# NOTE: the current aurora21.html is a CUSTOM hand-rolled build and does NOT
# consume this key — no 21.dev/Magic MCP was reachable at build time. This is
# documented here for whenever a real 21.dev source gets wired up.
21DEV_API_KEY=your_key_here
